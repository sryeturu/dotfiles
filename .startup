#!/usr/bin/env bash
# ===============================
# Startup Script for Polybar & GUI Apps
# ===============================

# ---------- Wallpaper ----------
WALLPAPER_PATH="$HOME/wallpapers/test.png"
feh --no-fehbg --bg-scale "$WALLPAPER_PATH" &

# ---------- Set Environment Variables ----------
# Wireless interface for Polybar
export POLYBAR_WIRELESS_IFACE=$(ip -brief link | awk '/wl/ {print $1; exit}')

# ---------- Monitor Setup ----------
xrandr --output HDMI-1 --off
monitor_count=$(xrandr | grep "\bconnected\b" | wc -l)

if [ "$monitor_count" -eq 2 ]; then
    xrandr --output HDMI-1 --auto --above eDP-1
    # Small sleep to let X11 settle after resolution changes
    sleep 1
fi

# ---------- Kill and Launch GUI Apps ----------
restart_app() {
    local app=$1
    # Kill the app and wait for it to actually die
    killall -q "$app"
    while pgrep -u $UID -x "$app" >/dev/null; do sleep 0.2; done
    "$app" &
}

restart_app picom
restart_app redshift
restart_app dunst
restart_app flameshot

# ---------- Polybar (need special handling) ----------
# 1. Kill all existing polybar instances
killall -q polybar

# 2. Wait until the processes have been shut down completely
while pgrep -u $UID -x polybar >/dev/null; do sleep 0.2; done

# 3. Launch Polybar for main display
MONITOR=eDP-1 polybar main &

# 4. Launch Polybar for HDMI-1 if connected
if [ "$monitor_count" -eq 2 ]; then
    MONITOR=HDMI-1 polybar main &
fi

echo "Desktop environment reloaded successfully."