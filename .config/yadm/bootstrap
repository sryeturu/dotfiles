#!/bin/bash

echo "--- Updating System Databases ---"
sudo pacman -Syu --noconfirm

if ! command -v paru &> /dev/null; then
    echo "--- Paru not found. Building from source... ---"
    
    sudo pacman -S --needed base-devel git --noconfirm
    
    # Create a clean temporary build space
    temp_dir=$(mktemp -d)
    git clone https://aur.archlinux.org/paru.git "$temp_dir"
    
    cd "$temp_dir" && makepkg -si --noconfirm
    
    # Clean up
    cd - && rm -rf "$temp_dir"
else
    echo "--- Paru is already installed. Checking for library health... ---"
    if ! paru -V &>/dev/null; then
        echo "--- Paru is broken (Library mismatch). Rebuilding... ---"
        temp_dir=$(mktemp -d)
        git clone https://aur.archlinux.org/paru.git "$temp_dir"
        cd "$temp_dir" && makepkg -si --noconfirm
        cd - && rm -rf "$temp_dir"
    fi
fi

# --- PACKAGE LIST ---
PACKAGES=(
    alsa-utils
    anki
    calibre
    conky
    cronie
    discord
    dunst
    dust
    efibootmgr
    feh
    flameshot
    font-manager
    ghostty
    google-chrome
    grub
    i3-wm
    i3lock
    light
    lxappearance
    man-pages
    nano
    networkmanager
    pcmanfm
    papirus-icon-theme
    pipewire
    pipewire-pulse
    wireplumber
    pavucontrol
    picom
    polybar
    redshift
    reflector
    rofi
    sudo
    tlp
    ttf-hack
    ttf-icomoon-feather
    ttf-roboto
    udiskie
    uv
    visual-studio-code-bin
    otf-font-awesome
    keepassxc
    xclip
    xdotool
    xorg-server
    xorg-xinit
    xorg-xrandr
    yadm
    zip
    openssh
    libinput
)

echo "--- Installing Packages from List ---"
paru -S --needed --noconfirm "${PACKAGES[@]}"

if ! groups "$USER" | grep -qw video; then
    echo "--- Adding $USER to video group (for brightness) ---"
    sudo usermod -aG video "$USER"
fi


echo "--- Enabling System Services ---"
sudo systemctl enable --now NetworkManager
sudo systemctl enable --now tlp
sudo systemctl enable --now cronie

echo "--- Enabling User Services ---"

systemctl --user enable pipewire pipewire-pulse wireplumber

echo "--- [ SUCCESS ] Bootstrap Complete! ---"
