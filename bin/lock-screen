#!/bin/bash

# Configuration
ICON="$HOME/.config/i3/lock.jpg"
IMG_SCREEN="/tmp/screen.png"
IMG_FINAL="/tmp/final.png"

# sleep so power menu has time to close
sleep .35

flameshot full -p "$IMG_SCREEN"

# 2. FFmpeg: Reduced blur and Center Overlay
# Changed boxblur from 15:5 to 5:1 for a subtle effect
ffmpeg -y -i "$IMG_SCREEN" -i "$ICON" -filter_complex \
"[0:v]boxblur=5:1[bg]; \
 [bg][1:v]overlay=(W-w)/2:(H-h)/2" \
-vframes 1 "$IMG_FINAL" -loglevel error

# 3. Lock the screen 
# -u (or --no-unlock-indicator) hides the flashing circle
i3lock -u -i "$IMG_FINAL"

# 4. Cleanup
rm "$IMG_SCREEN" "$IMG_FINAL"