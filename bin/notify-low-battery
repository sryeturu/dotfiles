#!/bin/bash

# 1. Path & Value Detection
BAT_DIR=$(ls -d /sys/class/power_supply/BAT* | head -n 1)
AC_DIR=$(ls -d /sys/class/power_supply/A* | head -n 1)

charge_level=$(cat "$BAT_DIR/capacity")
is_charging=$(cat "$AC_DIR/online")

# 2. Environment (Necessary for Cron/Systemd)
export DISPLAY=:0
export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"

# 3. Notification Logic
if [ "$is_charging" -eq 0 ] && [ "$charge_level" -le 25 ]; then
    dunstify " LOW BATTERY ${charge_level}%" -u critical -r 38294
fi